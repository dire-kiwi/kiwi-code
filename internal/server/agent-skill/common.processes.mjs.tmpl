const threadEndpoint = process.env.KIWI_CODE_THREAD_ENDPOINT?.replace(/\/+$/, "");

/* KIWI_CODE_SHARED_COMMON */

export function processApi(path = "") {
  if (!threadEndpoint) {
    throw new Error("KIWI_CODE_THREAD_ENDPOINT is not set. Run this helper from a Kiwi Code agent session.");
  }
  return `${threadEndpoint}/processes${path}`;
}

export function request(path = "", init = {}) {
  return requestURL(processApi(path), init);
}

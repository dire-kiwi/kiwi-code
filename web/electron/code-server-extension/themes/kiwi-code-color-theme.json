  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#666666",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables and tags",
      "scope": [
        "variable",
        "support.variable",
        "entity.name.tag",
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#cc6666"
      }
    },
    {
      "name": "Constants and attributes",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant",
        "entity.other.attribute-name",
        "support.constant"
      ],
      "settings": {
        "foreground": "#f0c674"
      }
    },
    {
      "name": "Classes and types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#e7c547"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "punctuation.definition.string",
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#b5bd68"
      }
    },
    {
      "name": "Operators, regexes, and builtins",
      "scope": [
        "keyword.operator",
        "string.regexp",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#8abeb7"
      }
    },
    {
      "name": "Functions and headings",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic",
        "markup.heading"
      ],
      "settings": {
        "foreground": "#81a2be"
      }
    },
    {
      "name": "Keywords and storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b294bb"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#c5c8c6"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#d54e53"
      }
    },
    {
      "name": "Markup emphasis",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#f0c674",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup italics",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#b294bb",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup quotes",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#81858a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Links",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#81a2be"
      }
    }
  ]
}
